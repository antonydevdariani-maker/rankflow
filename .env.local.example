# ──────────────────────────────────────────────
# RankFlow — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# Groq API key — used for article generation and SEO chat
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# GitHub Personal Access Token — needs repo write access
# Create at: https://github.com/settings/tokens
# Required scopes: repo (or contents:write on the target repo)
GITHUB_TOKEN=ghp_...

# Optional: override the default branch (defaults to "main")
# GITHUB_BRANCH=main
